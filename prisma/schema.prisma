// Lead Routing App — data model (SQLite for the MVP).
// All call state is persisted here; nothing critical lives only in memory,
// because Next.js route handlers are stateless and short-lived.
//
// NOTE: SQLite does not support Prisma `enum` blocks, so enum-like columns are
// stored as String. The allowed values + type-safe unions live in
// src/lib/enums.ts and are validated at the application layer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Lead {
  id     String  @id @default(cuid())
  name   String
  phone  String
  email  String?
  notes  String?
  status String  @default("NEW") // LeadStatus
  isDemo Boolean @default(false) // sample/demo data — removable from Settings

  // Caller-supplied idempotency key. When present, a repeated webhook delivery
  // with the same externalId is collapsed onto the existing lead instead of
  // creating a duplicate (and re-placing calls).
  externalId String?

  sourceId String?
  source   LeadSource? @relation(fields: [sourceId], references: [id])

  attempts   CallAttempt[]
  activities ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([externalId])
  // Hot path for dedupe + per-destination outbound-call caps.
  @@index([phone, createdAt])
}

model Agent {
  id           String    @id @default(cuid())
  name         String
  phone        String
  email        String?
  status       String    @default("AVAILABLE") // AgentStatus
  priority     Int       @default(0) // higher wins for PRIORITY strategy
  skills       String    @default("") // CSV; SQLite has no arrays
  active       Boolean   @default(true)
  lastRoutedAt DateTime? // round-robin ordering
  isDemo       Boolean   @default(false) // sample/demo data

  attempts CallAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Hottest routing query filters on active + status on every attempt.
  @@index([active, status])
}

model CallAttempt {
  id            String  @id @default(cuid())
  state         String  @default("PENDING") // CallAttemptState
  outcome       String? // CallOutcome
  attemptNumber Int     @default(1) // Nth agent dialed for this lead

  leadId  String
  lead    Lead   @relation(fields: [leadId], references: [id])
  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id])

  // Provider correlation
  agentCallSid   String?
  leadCallSid    String?
  conferenceName String?

  // Simulator scheduling — the "timer" persisted to the DB so transitions
  // survive across stateless requests.
  pendingLeg       String? // "agent" | "lead"
  pendingStatus    String? // e.g. "answered" | "no-answer" | "busy" | "failed" | "completed"
  nextTransitionAt DateTime?

  startedAt   DateTime  @default(now())
  bridgedAt   DateTime? // when both legs connected — basis for talk duration
  endedAt     DateTime?
  durationSec Int?
  isDemo      Boolean   @default(false) // sample/demo data

  activities ActivityLog[]

  @@index([state])
  @@index([nextTransitionAt])
  @@index([leadId])
  @@index([agentId])
  @@index([outcome])
}

model LeadSource {
  id              String  @id @default(cuid())
  name            String  @unique // "website", "facebook", "google-ads"
  label           String // human-friendly display name
  enabled         Boolean @default(true)
  routingStrategy String  @default("ROUND_ROBIN") // RoutingStrategy
  requiredSkill   String? // default skill requirement for this source
  priority        Int     @default(0)
  isDemo          Boolean @default(false) // sample/demo data

  leads Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoutingRule {
  id            String  @id @default(cuid())
  name          String
  enabled       Boolean @default(true)
  order         Int     @default(0) // lower = evaluated first
  sourceName    String? // null = applies to all sources
  strategy      String  @default("ROUND_ROBIN") // RoutingStrategy
  requiredSkill String?
  maxAttempts   Int     @default(3) // agent fallback cap

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled, order])
}

model BusinessHours {
  id          String  @id @default(cuid())
  dayOfWeek   Int     @unique // 0 = Sunday .. 6 = Saturday
  openMinute  Int     @default(540) // minutes from midnight (09:00)
  closeMinute Int     @default(1020) // 17:00; if <= openMinute the window is overnight (wraps past midnight)
  enabled     Boolean @default(true)
  timezone    String  @default("UTC")
}

model Holiday {
  id        String   @id @default(cuid())
  // Calendar date the business is closed. For non-recurring holidays the full
  // YYYY-MM-DD is matched; for recurring ones only month-day is matched.
  date      String // "YYYY-MM-DD"
  name      String
  recurring Boolean  @default(false) // repeats every year on the same month/day
  createdAt DateTime @default(now())

  @@index([date])
}

// Self-service telephony configuration, editable from Settings -> Telephony.
// A single row (id = "default"). Values here OVERRIDE the env defaults, so a
// user can connect their own phone number in the UI without redeploying. The
// auth token is write-only: it is stored but never returned to the browser.
model TelephonyConfig {
  id               String   @id @default("default")
  provider         String   @default("simulator") // "simulator" | "twilio"
  twilioAccountSid String?
  twilioAuthToken  String? // secret — never sent to the client
  twilioNumber     String?
  platformCallerId String?
  publicBaseUrl    String?
  updatedAt        DateTime @updatedAt
}

model ActivityLog {
  id      String  @id @default(cuid())
  type    String // ActivityType
  message String
  meta    String? // JSON string
  isDemo  Boolean @default(false) // sample/demo data

  leadId    String?
  lead      Lead?        @relation(fields: [leadId], references: [id])
  attemptId String?
  attempt   CallAttempt? @relation(fields: [attemptId], references: [id])

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([leadId])
}
