# Database (SQLite for the local MVP; use Postgres in production — see
# docs/GOING_TO_PRODUCTION.md)
DATABASE_URL="file:./dev.db"

# Telephony provider: "simulator" (default, no credentials) or "twilio"
PROVIDER="simulator"

# Caller ID the platform dials from
PLATFORM_CALLER_ID="+15555550123"

# Set to "1" to run an in-process ticker that advances the simulator hands-off
# (single-container only). When unset, the simulation advances on dashboard polls.
ENABLE_SIM_TICKER=""

# --- Security (opt-in locally; REQUIRED in production) ---
# When set, Basic-auth gates the dashboard + admin APIs. In production, leaving
# this unset FAILS CLOSED (protected routes return 503).
DASHBOARD_PASSWORD=""
# When set, /api/webhook/lead requires this token (header x-webhook-secret or
# ?token=). Required in production when PROVIDER=twilio.
LEAD_WEBHOOK_SECRET=""
# Number of trusted reverse proxies in front of the app (0 = trust the first
# X-Forwarded-For entry, correct on Vercel). Raise it to resist XFF spoofing
# when you control the proxy chain.
TRUSTED_PROXY_DEPTH="0"

# --- Outbound-call abuse caps (toll-fraud defense; applied when PROVIDER!=simulator) ---
MAX_GLOBAL_CALLS_PER_MIN="60"
MAX_CALLS_PER_DEST_PER_HOUR="5"

# --- Shared rate-limit store (recommended for serverless/multi-instance) ---
# When both are set the webhook rate limiter uses Upstash Redis instead of the
# per-process in-memory map.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Twilio (only needed when PROVIDER=twilio) ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_NUMBER=""
# Public base URL Twilio can reach for webhooks, e.g. https://your-domain.com
# Must EXACTLY match the origin Twilio calls (no trailing slash) or signature
# verification will reject every callback.
PUBLIC_BASE_URL=""
