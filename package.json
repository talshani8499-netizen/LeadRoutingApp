{
  "name": "lead-routing-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/prisma-prepare.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "prisma:prod:schema": "node scripts/build-prisma-schema.mjs",
    "db:push:prod": "node scripts/build-prisma-schema.mjs && prisma db push --schema prisma/schema.prod.prisma",
    "db:migrate:prod": "node scripts/build-prisma-schema.mjs && prisma migrate deploy --schema prisma/schema.prod.prisma",
    "db:seed:prod": "node scripts/build-prisma-schema.mjs && prisma generate --schema prisma/schema.prod.prisma && tsx prisma/seed.ts",
    "twilio:check": "tsx scripts/twilio-smoke-test.ts",
    "test": "vitest run"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@upstash/redis": "^1.38.0",
    "next": "^15.5.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "twilio": "^6.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.4.38",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5"
  }
}
